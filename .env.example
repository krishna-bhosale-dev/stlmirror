VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Cloudflare R2 (server-side only — NO VITE_ prefix) ─────────────────────────
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=stlmirror-files
R2_PUBLIC_URL=https://pub-xxxx.r2.dev   # or your custom domain

# ── API base ─────────────────────────────────────────────────────────────────
# IMPORTANT: Leave blank! Vite bakes VITE_* vars into the production bundle, so
# setting this to http://localhost:3001 will break all API calls on Vercel.
# When blank, fetch() uses relative paths (/api/upload) which work everywhere:
#   • Vite dev server  → proxied to localhost:3001 via vite.config.js
#   • Vercel production → served by Vercel serverless functions
VITE_API_BASE=
